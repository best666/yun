{
  "name": "yun-food",
  "version": "0.0.1",
  "private": true,
  "description": "美食小程序 monorepo 项目",
  "scripts": {
    "dev:app": "pnpm --filter @yun/app dev",
    "dev:server": "pnpm --filter @yun/server dev",
    "build:app": "pnpm --filter @yun/app build",
    "build:server": "pnpm --filter @yun/server build",
    "db:migrate": "pnpm --filter @yun/server db:migrate",
    "db:generate": "pnpm --filter @yun/server db:generate",
    "db:studio": "pnpm --filter @yun/server db:studio",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "@swc/core",
      "@nestjs/core"
    ]
  }
}
