generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户模块 ====================

/// 用户表
model User {
  id            Int      @id @default(autoincrement())
  username      String?  @unique @db.VarChar(50)
  openid        String?  @unique @db.VarChar(64) /// 微信小程序openid
  wechatOpenId  String?  @unique @map("wechat_open_id") @db.VarChar(64)
  douyinOpenId  String?  @unique @map("douyin_open_id") @db.VarChar(64)
  unionId       String?  @map("union_id") @db.VarChar(64)
  nickname      String?  @db.VarChar(50)
  avatar        String?  @db.VarChar(500)
  phone         String?  @unique @db.VarChar(20)
  gender        Int      @default(0) /// 0未知 1男 2女
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  favorites   Favorite[]
  reviews     Review[]
  collections Collection[]
  smsCodes    SmsCode[]
  spotReviews SpotReview[]
  spotFavorites SpotFavorite[]
  spotDiscussions SpotDiscussion[]
  spotDiscussionLikes SpotDiscussionLike[]
  spotNotes SpotNote[]
  spotNoteLikes SpotNoteLike[]
  spotQuestions SpotQuestion[]
  spotQuestionAnswers SpotQuestionAnswer[]
  /// 收到的互动提醒
  spotInteractionNotifications SpotInteractionNotification[] @relation("SpotInteractionNotificationRecipient")
  /// 触发互动提醒的操作者记录
  spotInteractionNotificationActors SpotInteractionNotification[] @relation("SpotInteractionNotificationActor")

  @@map("users")
}

model SmsCode {
  id        Int       @id @default(autoincrement())
  userId    Int?      @map("user_id")
  phone     String    @db.VarChar(20)
  code      String    @db.VarChar(10)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([phone, createdAt])
  @@index([expiresAt])
  @@map("sms_codes")
}

// ==================== 美食模块 ====================

/// 美食分类
model Category {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  icon      String?  @db.VarChar(500)
  sort      Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  foods Food[]

  @@map("categories")
}

/// 美食
model Food {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  cover       String?  @db.VarChar(500) /// 封面图
  images      String?  @db.Text /// JSON 图片数组
  price       Decimal? @db.Decimal(10, 2)
  tags        String?  @db.VarChar(500) /// 标签，逗号分隔
  categoryId  Int      @map("category_id")
  shopId      Int?     @map("shop_id")
  isActive    Boolean  @default(true) @map("is_active")
  viewCount   Int      @default(0) @map("view_count")
  likeCount   Int      @default(0) @map("like_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category  Category   @relation(fields: [categoryId], references: [id])
  shop      Shop?      @relation(fields: [shopId], references: [id])
  favorites Favorite[]
  reviews   Review[]

  @@index([categoryId])
  @@index([shopId])
  @@map("foods")
}

// ==================== 店铺模块 ====================

/// 店铺
model Shop {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  cover       String?  @db.VarChar(500)
  address     String?  @db.VarChar(300)
  phone       String?  @db.VarChar(20)
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  rating      Decimal  @default(0) @db.Decimal(2, 1)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  foods Food[]

  @@map("shops")
}

/// 地点
model Spot {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  description     String?  @db.Text
  cover           String?  @db.VarChar(500)
  images          String?  @db.Text
  address         String?  @db.VarChar(300)
  phone           String?  @db.VarChar(20)
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
  rating          Decimal  @default(0) @db.Decimal(2, 1)
  avgPrice        Int      @default(0) @map("avg_price")
  favoriteCount   Int      @default(0) @map("favorite_count")
  businessStatus  String?  @map("business_status") @db.VarChar(30)
  businessHours   String?  @map("business_hours") @db.VarChar(100)
  routeTip        String?  @map("route_tip") @db.VarChar(200)
  navigationLabel String?  @map("navigation_label") @db.VarChar(200)
  tags            String?  @db.VarChar(500)
  sourceType      String   @default("manual") @map("source_type") @db.VarChar(30)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  externalSources SpotExternalSource[]
  reviews         SpotReview[]
  discussions     SpotDiscussion[]
  favorites       SpotFavorite[]
  notes           SpotNote[]
  questions       SpotQuestion[]
  interactionNotifications SpotInteractionNotification[]

  @@index([sourceType])
  @@index([name])
  @@map("spots")
}

/// 地图外部来源映射
model SpotExternalSource {
  id         Int      @id @default(autoincrement())
  spotId      Int      @map("spot_id")
  provider    String   @db.VarChar(20)
  externalId  String   @map("external_id") @db.VarChar(120)
  title       String?  @db.VarChar(100)
  address     String?  @db.VarChar(300)
  category    String?  @db.VarChar(200)
  district    String?  @db.VarChar(100)
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  spot Spot @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([spotId])
  @@index([externalId])
  @@map("spot_external_sources")
}

/// 地点评价
model SpotReview {
  id        Int      @id @default(autoincrement())
  spotId     Int      @map("spot_id")
  userId     Int?     @map("user_id")
  userName   String   @map("user_name") @db.VarChar(50)
  avatar     String?  @db.VarChar(500)
  content    String   @db.Text
  rating     Int      @default(5)
  images     String?  @db.Text
  likeCount  Int      @default(0) @map("like_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  spot Spot  @relation(fields: [spotId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([spotId, createdAt])
  @@index([userId])
  @@map("spot_reviews")
}

/// 地点讨论
model SpotDiscussion {
  id        Int      @id @default(autoincrement())
  spotId     Int      @map("spot_id")
  userId     Int?     @map("user_id")
  userName   String   @map("user_name") @db.VarChar(50)
  avatar     String?  @db.VarChar(500)
  content    String   @db.Text
  likeCount  Int      @default(0) @map("like_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  spot Spot @relation(fields: [spotId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  likes SpotDiscussionLike[]

  @@index([spotId, createdAt])
  @@index([userId])
  @@map("spot_discussions")
}

/// 地点收藏
model SpotFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  spotId     Int      @map("spot_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot Spot @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@unique([userId, spotId])
  @@index([spotId])
  @@map("spot_favorites")
}

/// 地点讨论点赞
model SpotDiscussionLike {
  id            Int      @id @default(autoincrement())
  discussionId  Int      @map("discussion_id")
  userId        Int      @map("user_id")
  createdAt     DateTime @default(now()) @map("created_at")

  discussion SpotDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([discussionId, userId])
  @@index([userId])
  @@map("spot_discussion_likes")
}

/// 地点笔记
model SpotNote {
  id        Int      @id @default(autoincrement())
  spotId     Int      @map("spot_id")
  userId     Int?     @map("user_id")
  userName   String   @map("user_name") @db.VarChar(50)
  avatar     String?  @db.VarChar(500)
  title      String   @db.VarChar(100)
  content    String   @db.Text
  cover      String?  @db.VarChar(500)
  likeCount  Int      @default(0) @map("like_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  spot Spot @relation(fields: [spotId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  likes SpotNoteLike[]

  @@index([spotId, createdAt])
  @@index([userId])
  @@map("spot_notes")
}

/// 地点笔记点赞
model SpotNoteLike {
  id        Int      @id @default(autoincrement())
  noteId    Int      @map("note_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  note SpotNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId])
  @@index([userId])
  @@map("spot_note_likes")
}

/// 地点问答
model SpotQuestion {
  id          Int      @id @default(autoincrement())
  spotId      Int      @map("spot_id")
  userId      Int?     @map("user_id")
  userName    String   @map("user_name") @db.VarChar(50)
  avatar      String?  @db.VarChar(500)
  question    String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  spot Spot @relation(fields: [spotId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers SpotQuestionAnswer[]

  @@index([spotId, createdAt])
  @@index([userId])
  @@map("spot_questions")
}

/// 地点问答回复
model SpotQuestionAnswer {
  id          Int      @id @default(autoincrement())
  questionId  Int      @map("question_id")
  userId      Int?     @map("user_id")
  userName    String   @map("user_name") @db.VarChar(50)
  avatar      String?  @db.VarChar(500)
  content     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  question SpotQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([questionId, createdAt])
  @@index([userId])
  @@map("spot_question_answers")
}

/// 地点互动提醒
model SpotInteractionNotification {
  id              Int       @id @default(autoincrement())
  recipientUserId Int       @map("recipient_user_id")
  actorUserId     Int?      @map("actor_user_id")
  spotId          Int?      @map("spot_id")
  type            String    @db.VarChar(30)
  title           String    @db.VarChar(100)
  content         String    @db.VarChar(500)
  targetType      String?   @map("target_type") @db.VarChar(30)
  targetId        Int?      @map("target_id")
  isRead          Boolean   @default(false) @map("is_read")
  readAt          DateTime? @map("read_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  recipientUser User @relation("SpotInteractionNotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actorUser User? @relation("SpotInteractionNotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  spot Spot? @relation(fields: [spotId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, isRead, createdAt])
  @@index([actorUserId])
  @@index([spotId])
  @@map("spot_interaction_notifications")
}

// ==================== 互动模块 ====================

/// 收藏
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  foodId    Int      @map("food_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  food Food @relation(fields: [foodId], references: [id])

  @@unique([userId, foodId])
  @@map("favorites")
}

/// 评价
model Review {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  foodId    Int      @map("food_id")
  content   String?  @db.Text
  rating    Int      @default(5) /// 1-5星
  images    String?  @db.Text /// JSON 图片数组
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  food Food @relation(fields: [foodId], references: [id])

  @@index([userId])
  @@index([foodId])
  @@map("reviews")
}

/// 用户收藏夹
model Collection {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @db.VarChar(50)
  cover     String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("collections")
}
