# 服务端口
PORT=3000

# 服务端基础地址，用于第三方登录回调拼接
SERVER_BASE_URL="http://localhost:3000"

# JWT 配置
JWT_SECRET="replace-with-a-strong-secret"
JWT_EXPIRES_IN_SECONDS=604800

# 开发环境验证码调试开关，true 时接口会直接返回验证码
SMS_DEBUG_RETURN_CODE=true

# 本地联调固定验证码，仅开发环境使用；留空则关闭
DEV_FIXED_SMS_CODE=""
DEV_FIXED_SMS_PHONES=""

# 高德 WebService Key，用于地点搜索接口
AMAP_KEY=""
AMAP_KEY_BACKUP=""

# 腾讯地图 WebService Key，用于设置中切换为腾讯地图时的地点搜索接口
TENCENT_MAP_KEY=""
TENCENT_MAP_KEY_BACKUP=""

# 数据库连接（请修改为你的实际数据库信息）
DATABASE_URL="mysql://root:password@127.0.0.1:3306/yun_food"

# 微信小程序登录
WECHAT_MP_APPID=""
WECHAT_MP_SECRET=""

# H5 微信开放平台登录
WECHAT_OAUTH_APPID=""
WECHAT_OAUTH_SECRET=""

# H5 抖音开放平台登录
DOUYIN_CLIENT_KEY=""
DOUYIN_CLIENT_SECRET=""
